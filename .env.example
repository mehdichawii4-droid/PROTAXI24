# PROTAXI24 — copy to `.env` for local overrides (never commit real secrets).

# Expo / EAS
EXPO_PUBLIC_EAS_PROJECT_ID=6650d953-f840-42a9-8e99-edf8629a1042

# Google Maps (client-side key — restrict by bundle id in Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Firebase Web client config (public client SDK keys)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Callable Cloud Functions region
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=europe-west1

# Optional future REST API
EXPO_PUBLIC_API_BASE_URL=

# Dev-only bootstrap admin (remove or empty in production builds)
EXPO_PUBLIC_BOOTSTRAP_ADMIN_EMAIL=
EXPO_PUBLIC_BOOTSTRAP_ADMIN_PASSWORD=

# Feature flags (true | false)
EXPO_PUBLIC_ENABLE_CHAT_PUSH=true
EXPO_PUBLIC_ENABLE_RIDE_PAYMENT=true
EXPO_PUBLIC_ENABLE_RATINGS_V2=true
